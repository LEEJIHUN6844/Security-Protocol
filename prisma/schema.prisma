// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  image         String?
  
  // 인증서 관련 필드
  certificate   String?   // 발급된 PEM 형식의 인증서 저장
  publicKey     String?   // 사용자의 공개키 저장
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Message {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  senderEmail      String
  receiverEmail    String
  encryptedContent String   // AES로 암호화된 (본문+서명) JSON 데이터
  encryptedKey     String   // 수신자 공개키로 RSA 암호화된 AES 키 (전자봉투)
  iv              String   // AES 초기화 벡터
  
  createdAt        DateTime @default(now())

  @@index([receiverEmail])
}